<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="stars_beyond.GameplayPageMainUI"
             Background="Black">

    <Grid RowDefinitions="Auto,Auto,Auto,Auto" Padding="10" RowSpacing="10" VerticalOptions="End">
        <VerticalStackLayout>
            <Frame 
                Grid.Row="0"
                HeightRequest="350"
                BackgroundColor="Black"
                HasShadow="False"
                Padding="0"
                HorizontalOptions="Center"
                Margin="0,0,0,-2">
                <Image 
                    x:Name="CharacterImage"
                    Source="concept_1.png"
                    Aspect="AspectFit"/>
            </Frame>
            <Border 
                Stroke="White"
                StrokeThickness="4"
                BackgroundColor="Black"
                Padding="15"
                HeightRequest="180">
                 <Label x:Name="DialogLabel"
                     Text="* Placeholder Text"
                     TextColor="White"
                     FontFamily="Determination"
                     FontSize="25"/>
            </Border>
        </VerticalStackLayout>
        <Grid 
            Grid.Row="2" 
            ColumnDefinitions="*,Auto" 
            VerticalOptions="Center" 
            HeightRequest="35">
            <Label 
                x:Name="NameLabel"
                Text="KITH  LV1"
                TextColor="White"
                FontFamily="Determination"
                FontSize="25"
                VerticalOptions="Center"/>

            <Grid
                HorizontalOptions="End" 
                VerticalOptions="Center">
                <Label
                    Text="HP"
                    TextColor="White"
                    FontSize="25"
                    FontFamily="Determination"
                    Margin="45,0,0,0"/>
                <BoxView 
                    Color="Gray" 
                    WidthRequest="45" 
                    HeightRequest="13"/>
                <BoxView 
                    x:Name="HpBar" 
                    Color="Yellow" 
                    WidthRequest="45" 
                    HeightRequest="13"/>
                <Label 
                    x:Name="HpLabel"
                    Text="20/20"
                    TextColor="White"
                    FontSize="25"
                    FontFamily="Determination"
                    Margin="140,0,0,0"/>
            </Grid>
        </Grid>
        <Grid Grid.Row="3" ColumnDefinitions="*,*" RowDefinitions="*,*" RowSpacing="10" ColumnSpacing="10">
            <Button 
                Grid.Row="0" 
                Grid.Column="0"
                HeightRequest="60"
                BackgroundColor="Black"
                BorderColor="#EA260C"
                BorderWidth="4"
                CornerRadius="0"
                ImageSource="fight_icon.png"
                Padding="4"/>
            <Button 
                Grid.Row="0" 
                Grid.Column="1"
                HeightRequest="60"
                BackgroundColor="Black"
                BorderColor="#EA260C"
                BorderWidth="4"
                CornerRadius="0"
                ImageSource="act_icon.png"
                Padding="4">
                
            </Button>
            <Button 
                Grid.Row="1" 
                Grid.Column="0"
                HeightRequest="60"
                BackgroundColor="Black"
                BorderColor="#EA260C"
                BorderWidth="4"
                CornerRadius="0"
                ImageSource="item_icon.png"
                Padding="4"/>
            <Button 
                Grid.Row="1" 
                Grid.Column="1"
                HeightRequest="60"
                BackgroundColor="Black"
                BorderColor="#EA260C"
                BorderWidth="4"
                CornerRadius="0"
                ImageSource="mercy_icon.png"
                Padding="4"/>
        </Grid>
    </Grid>
</ContentPage>