<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="stars_beyond.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:stars_beyond"
    Title="stars_beyond"
    FlyoutBehavior="Disabled">

    <ShellContent
      Title=""
      ContentTemplate="{DataTemplate local:IntroPage}"
      Route="IntroPage" />
    <ShellContent
        Title=""
        ContentTemplate="{DataTemplate local:MainMenu}"
        Route="MainMenu" />
    <ShellContent
     Title=""
     ContentTemplate="{DataTemplate local:GameplayPage}"
     Route="GameplayPage" />

</Shell>
