<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="stars_beyond.MainMenu">
    <ContentPage.Background>

        <LinearGradientBrush EndPoint="0,3">
            <GradientStop Color="Black"
                          Offset="-0.05" />
            <GradientStop Color="#5E00FF"
                          Offset="1" />
        </LinearGradientBrush>
    </ContentPage.Background>
    <Grid>
        <VerticalStackLayout>
            <Image Source="stars_beyond_logo.png" WidthRequest="325"/>
        </VerticalStackLayout>
        <VerticalStackLayout VerticalOptions="End">
            <Button  Margin="0,0,0,0" CornerRadius="0" BackgroundColor="Black" BorderWidth="4" BorderColor="White" HeightRequest="60" Text="START" TextColor="White" FontSize="32" FontFamily="Determination"/>
            <Button Margin="0,-4,0,0" CornerRadius="0" BackgroundColor="Black" BorderWidth="4" BorderColor="White" HeightRequest="60" Text="OPTIONS" TextColor="White" FontSize="32" FontFamily="Determination"/>
            <Button Margin="0,-4,0,0" CornerRadius="0" BackgroundColor="Black" BorderWidth="4" BorderColor="White" HeightRequest="60" Text="CREDITS" TextColor="White" FontSize="32" FontFamily="Determination"/>
            <Button Margin="0,-4,0,0" CornerRadius="0" BackgroundColor="Black" BorderWidth="4" BorderColor="White" HeightRequest="60" Text="EXIT" TextColor="White" FontSize="32" FontFamily="Determination"/>
        </VerticalStackLayout>
    </Grid>
</ContentPage>